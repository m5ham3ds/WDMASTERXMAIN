<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Dark Application Theme -->
    <style name="Theme.WDMaster" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/text_white</item>
        
        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/accent</item>
        <item name="colorSecondaryVariant">@color/accent</item>
        <item name="colorOnSecondary">@color/text_white</item>
        
        <!-- Status bar color -->
        <item name="android:statusBarColor">@color/background_dark</item>
        
        <!-- Background -->
        <item name="android:colorBackground">@color/background_light</item>
        <item name="colorSurface">@color/surface_light</item>
        <item name="colorOnSurface">@color/text_primary</item>
        
        <!-- Navigation -->
        <item name="bottomNavigationStyle">@style/Widget.WDMaster.BottomNavigation.Dark</item>
    </style>
    
    <!-- Bottom Navigation Style (Dark) -->
    <style name="Widget.WDMaster.BottomNavigation.Dark" parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">@color/surface_light</item>
        <item name="itemIconTint">@color/nav_selector</item>
        <item name="itemTextColor">@color/nav_selector</item>
    </style>
</resources>