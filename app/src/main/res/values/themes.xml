<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base Application Theme -->
    <style name="Theme.WDMaster" parent="Theme.Material3.Light.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/text_white</item>
        
        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/accent</item>
        <item name="colorSecondaryVariant">@color/accent</item>
        <item name="colorOnSecondary">@color/text_white</item>
        
        <!-- Status bar color -->
        <item name="android:statusBarColor">@color/primary_dark</item>
        
        <!-- Background -->
        <item name="android:colorBackground">@color/background_light</item>
        <item name="colorSurface">@color/surface_light</item>
        <item name="colorOnSurface">@color/text_primary</item>
        
        <!-- Navigation -->
        <item name="bottomNavigationStyle">@style/Widget.WDMaster.BottomNavigation</item>
    </style>
    
    <!-- Bottom Navigation Style -->
    <style name="Widget.WDMaster.BottomNavigation" parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">@color/surface_light</item>
        <item name="itemIconTint">@color/nav_selector</item>
        <item name="itemTextColor">@color/nav_selector</item>
    </style>
    
    <!-- Card Style -->
    <style name="Widget.WDMaster.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardElevation">4dp</item>
        <item name="cardCornerRadius">12dp</item>
    </style>
    
    <!-- Button Style -->
    <style name="Widget.WDMaster.Button" parent="Widget.Material3.Button">
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">8dp</item>
    </style>
    
    <!-- Terminal Text Style -->
    <style name="TextAppearance.WDMaster.Terminal" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:fontFamily">monospace</item>
        <item name="android:textSize">12sp</item>
    </style>
    
    <!-- Stats Text Style -->
    <style name="TextAppearance.WDMaster.Stats" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textStyle">bold</item>
    </style>
</resources>